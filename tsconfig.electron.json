{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist-electron",
    "rootDir": ".",
    "noEmit": false,
    "isolatedModules": false,
    "moduleDetection": "auto",
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "electron-main.ts",
    "src/db.ts",
    "src/preload.ts",
    "src/types.ts"
  ]
}
